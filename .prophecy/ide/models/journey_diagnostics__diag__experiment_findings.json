          },
          "alias" : "conversions",
          "_row_id" : "74792281"
        }, {
          "expression" : {
            "expression" : "CAST(bounces AS BIGINT)"
          },
          "alias" : "bounces",
          "_row_id" : "1228100426"
        }, {
          "expression" : {
            "expression" : "CAST(CASE\n  WHEN sessions > 0\n    THEN CAST(conversions AS DOUBLE) / CAST(sessions AS DOUBLE)\n  ELSE 0.0\nEND AS DOUBLE)"
          },
          "alias" : "session_conversion_rate",
          "_row_id" : "2002711910"
        }, {
          "expression" : {
            "expression" : "CAST(CASE\n  WHEN sessions > 0\n    THEN CAST(bounces AS DOUBLE) / CAST(sessions AS DOUBLE)\n  ELSE 0.0\nEND AS DOUBLE)"
          },
          "alias" : "bounce_rate",
          "_row_id" : "1994226045"
        }, {
          "expression" : {
            "expression" : "CAST(CASE\n  WHEN baseline_sessions > 0 AND sessions > 0\n    THEN (\n      (CAST(conversions AS DOUBLE) / CAST(sessions AS DOUBLE))\n      - (CAST(baseline_conversions AS DOUBLE) / CAST(baseline_sessions AS DOUBLE))\n    )\n    / (CAST(baseline_conversions AS DOUBLE) / CAST(baseline_sessions AS DOUBLE))\n  ELSE NULL\nEND AS DOUBLE)"
          },
          "alias" : "relative_lift",
          "_row_id" : "385213811"
        }, {
          "expression" : {
            "expression" : "CAST(CASE\n  WHEN baseline_sessions > 0\n  AND sessions > 0\n  AND (CAST(conversions AS DOUBLE) / CAST(sessions AS DOUBLE)) > (CAST(baseline_conversions AS DOUBLE) / CAST(baseline_sessions AS DOUBLE))\n    THEN 'positive'\n  WHEN baseline_sessions > 0\n  AND sessions > 0\n  AND (CAST(conversions AS DOUBLE) / CAST(sessions AS DOUBLE)) < (CAST(baseline_conversions AS DOUBLE) / CAST(baseline_sessions AS DOUBLE))\n    THEN 'negative'\n  ELSE 'neutral'\nEND AS STRING)"
          },
          "alias" : "finding_direction",
          "_row_id" : "1977136140"
        } ]
