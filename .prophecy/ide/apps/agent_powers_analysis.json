  },
  "definition" : {
    "template" : [ {
      "key" : "8ddea63cd3cc425fa2849",
      "id" : "Text1",
      "type" : "Text",
      "properties" : {
        "content" : "# Agent Powers Showcase Dashboard\n\nThis dashboard demonstrates the comprehensive capabilities of Prophecy's Analysis framework:\n\n- **Interactive Charts**: Bar, Line, and Pie charts with configurable axes\n- **Configuration Widgets**: Dropdowns, number inputs, date pickers, and toggles\n- **Real-time Data**: Connected to pipeline outputs via Visualize gems\n- **Scheduling**: Automated execution with email notifications\n\n---"
      }
    }, {
      "key" : "fcaa47a0c5ab46198336e",
      "id" : "NumberInput1",
      "type" : "NumberInput",
      "properties" : {
        "configField" : "min_orders_threshold",
        "label" : "Minimum Orders Threshold",
        "helpText" : "Filter products with at least this many orders",
        "tooltip" : "Higher values show only high-volume products",
        "isRequired" : false,
        "defaultValue" : 10
      }
    }, {
      "key" : "d5d86e6a2aa94a38a6ecf",
      "id" : "NumberInput2",
      "type" : "NumberInput",
      "properties" : {
        "configField" : "revenue_threshold",
        "label" : "Revenue Threshold ($)",
        "helpText" : "Minimum net revenue to include in analysis",
        "tooltip" : "Filter out low-revenue products",
        "isRequired" : false,
        "defaultValue" : 500
      }
    }, {
      "key" : "d4d5ed0cd671440ab7d69",
      "id" : "Date1",
      "type" : "Date",
      "properties" : {
        "configField" : "analysis_start_date",
        "label" : "Analysis Start Date",
        "helpText" : "Only include data from this date forward",
        "tooltip" : "Earlier dates provide more historical context",
        "isRequired" : false,
        "format" : "MMMM d, yyyy",
        "firstDay" : "Sunday",
        "defaultValue" : "2014/01/01"
      }
    }, {
      "key" : "ac0267257a994ef487c27",
      "id" : "Checkbox1",
      "type" : "Checkbox",
      "properties" : {
        "configField" : "include_refunds",
        "label" : "Include Refunded Items",
        "helpText" : "When unchecked, excludes products with refunds from final output",
        "tooltip" : "Toggle to see impact of refunds on product performance",
        "isRequired" : false,
        "defaultValue" : false
      }
    }, {
      "key" : "02e848d8657f4cd48363e",
      "id" : "TextInput1",
      "type" : "TextInput",
      "properties" : {
        "configField" : "product_filter",
        "label" : "Product Name Filter",
        "helpText" : "SQL LIKE pattern to filter products (e.g., '%Bear%')",
        "tooltip" : "Use % as wildcard",
        "isRequired" : false,
        "defaultValue" : ""
